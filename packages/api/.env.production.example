# === Database ===
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/spaceplanner

# === Auth ===
SECRET_KEY=your-very-long-secret-key-here-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === AI APIs ===
ANTHROPIC_API_KEY=sk-ant-...
STABILITY_API_KEY=sk-...

# === Storage (MinIO / S3) ===
S3_BUCKET=spaceplanner
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# === Redis ===
REDIS_URL=redis://host:6379

# === CORS ===
FRONTEND_URL=https://spaceplanner.kr

# === Toss Payments (결제) ===
TOSS_CLIENT_KEY=live_ck_...
TOSS_SECRET_KEY=live_sk_...

# === Sentry ===
SENTRY_DSN=https://...@sentry.io/...
